AI_DAILY_BRIEF_API_KEY=your_api_key_here
AI_DAILY_BRIEF_MODEL=your_model_name_here
# 可选：如使用 OpenAI 兼容接口，可填服务 base URL；
# 若留空，默认使用 https://api.openai.com/v1/chat/completions
# AI_DAILY_BRIEF_BASE_URL=https://api.openai.com/v1

# 可选：如需自动发布为可分享 HTTPS 链接
# AI_DAILY_BRIEF_PUBLISH_OWNER=your_github_username
# AI_DAILY_BRIEF_PUBLISH_REPO=ai-daily-brief-share
# AI_DAILY_BRIEF_PUBLISH_SUBDIR=ai-daily-brief
# AI_DAILY_BRIEF_PUBLISH_TOKEN=your_github_token_here
